# ===== 環境変数テンプレート =====
# このファイルを .env.local にコピーしてローカル開発に使用
# 本番値はNetlifyダッシュボードの "Environment variables" に設定すること
# .env.local はGitに含めないこと（.gitignoreに記載済み）

# サイトのベースURL（末尾スラッシュなし）
SITE_URL=https://sekoukan-agent.netlify.app

# Google Sheets API
# 取得方法: Google Cloud Console → APIs & Services → Credentials
GOOGLE_SHEETS_API_KEY=AIza_ここにAPIキーを入力

# スプレッドシートのID
# URLの https://docs.google.com/spreadsheets/d/【ここ】/edit から取得
GOOGLE_SPREADSHEET_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ_ここにIDを入力
